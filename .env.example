# Required: Cosense project name
COSENSE_PROJECT_NAME=your-project-name

# Required for private projects and write operations: connect.sid cookie value
COSENSE_SID=

# Transport mode: "http" for Claude.ai Custom Connector, "stdio" for Claude Desktop (default)
TRANSPORT=http

# HTTP server port (only used when TRANSPORT=http)
PORT=3000

# Optional: Bearer token for HTTP endpoint authentication
MCP_AUTH_TOKEN=

# Optional: Page limit for initial resource listing (1-1000, default: 100)
# COSENSE_PAGE_LIMIT=100

# Optional: Sort method for page listing (updated|created|accessed|linked|views|title)
# COSENSE_SORT_METHOD=updated

# Optional: Exclude pinned pages from listing
# COSENSE_EXCLUDE_PINNED=false
